///Floor[Log(b)  N] + 1 = the number of digits when any number is represented in base b
using namespace std;
typedef long long ll;


int main()
{
    ll tst,n,num;
    cin>>tst;
    while(tst--)
    {
        ll even=0,odd=0;
        cin>>n;
        for(ll i=0;i<n;i++)
        {
            cin>>num;
            if(num%2==0) even+=num;
            else odd+=num;
        }
        if(even>odd) cout<<"YES"<<endl;
        else cout<<"NO"<<endl;
    }
    return 0;
}
